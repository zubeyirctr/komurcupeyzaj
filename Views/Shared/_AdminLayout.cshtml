<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin | Kömürcü Peyzaj</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <!-- Sidebar -->
    <nav class="admin-sidebar d-flex flex-column py-4">
        <div class="px-4 mb-5">
            <a asp-controller="Home" asp-action="Index" class="admin-logo">
                Kömürcü <span>Peyzaj</span>
            </a>
            <div class="admin-role">Yönetim Paneli</div>
        </div>
        <ul class="nav flex-column flex-grow-1 px-2">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Urun") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Urunler">
                    <i class="bi bi-box-seam"></i> <span>Ürünler</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Hizmet") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Hizmetler">
                    <i class="bi bi-tree"></i> <span>Hizmetler</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Proje") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Projeler">
                    <i class="bi bi-images"></i> <span>Projeler</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Referans") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Referanslar">
                    <i class="bi bi-star"></i> <span>Referanslar</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Blog") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Blog">
                    <i class="bi bi-journal-text"></i> <span>Blog</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("SSS") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="SSS">
                    <i class="bi bi-question-circle"></i> <span>SSS</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Mesaj") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Mesajlar">
                    <i class="bi bi-envelope"></i> <span>Mesajlar</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Ekip") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Ekip">
                    <i class="bi bi-people"></i> <span>Ekip</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.Contains("Ayar") == true ? "active" : "")"
                   asp-controller="Admin" asp-action="Ayarlar">
                    <i class="bi bi-gear"></i> <span>Ayarlar</span>
                </a>
            </li>
        </ul>
        <div class="px-4 mt-auto">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm w-100">
                <i class="bi bi-arrow-left me-1"></i> Siteye Dön
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="admin-content">
        <div class="admin-topbar">
            <h6 class="mb-0">@ViewData["Title"]</h6>
            <small><i class="bi bi-person-circle me-1"></i> Admin</small>
        </div>
        <div class="admin-inner p-4">
            @if (TempData["Basari"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Basari"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Hata"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["Hata"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
