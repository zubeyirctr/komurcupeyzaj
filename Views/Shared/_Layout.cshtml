<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Kömürcü Peyzaj</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Profesyonel peyzaj tasarımı ve uygulama hizmetleri. Bahçe tasarımı, rulo çim, sulama sistemleri ve daha fazlası.")" />
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Sayfa Geçiş Overlay ──────────────────────────────── -->
    <div id="page-transition">
        <img src="/images/logo.png" class="pt-logo-img" alt="Kömürcü Peyzaj" onerror="this.style.display='none';document.getElementById('pt-fallback').style.display='block'" />
        <span id="pt-fallback" style="display:none;font-family:'Cormorant Garamond',serif;font-size:2rem;color:#fff;letter-spacing:3px">
            Kömürcü <span style="color:#c9a84c">Peyzaj</span>
        </span>
    </div>

    <!-- ── Üst İnce Bar ─────────────────────────────────────── -->
    <div class="top-bar d-none d-md-block">
        <div class="container d-flex justify-content-between align-items-center">
            <!-- Sol: Logo küçük + Telefon -->
            <div class="top-bar-left d-flex align-items-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="top-bar-logo">
                    <img src="/images/logo.png" alt="Kömürcü Peyzaj"
                         onerror="this.style.display='none'" />
                    <span>Kömürcü <em>Peyzaj</em></span>
                </a>
                @{
                    var ayarlarTop = ViewBag.Ayarlar as KomürcüPeyzaj.Models.SiteAyarlari;
                    var telTop = ayarlarTop?.Telefon ?? "0530 096 70 91";
                    var waTop  = ayarlarTop?.WhatsApp ?? "https://wa.me/905300967091";
                }
                <a href="tel:@telTop.Replace(" ", "")" class="top-bar-tel">
                    <i class="bi bi-telephone-fill"></i> @telTop
                </a>
            </div>
            <!-- Sağ: Sosyal medya -->
            <div class="top-bar-right d-flex gap-3 align-items-center">
                @{
                    var igTop  = ayarlarTop?.Instagram ?? "#";
                    var ttTop  = ayarlarTop?.TikTok ?? "#";
                }
                <a href="@igTop" target="_blank" rel="noopener" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                <a href="@waTop" target="_blank" rel="noopener" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                <a href="@ttTop" target="_blank" rel="noopener" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
            </div>
        </div>
    </div>

    <!-- ── Ana Navbar ────────────────────────────────────────── -->
    <nav id="main-navbar" class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Kömürcü <span>Peyzaj</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarMain" aria-expanded="false" aria-label="Menüyü aç">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">Anasayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hizmet" ? "active" : "")"
                           asp-controller="Hizmet" asp-action="Index">Hizmetler</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Urun" ? "active" : "")"
                           asp-controller="Urun" asp-action="Index">Ürünler</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Proje" ? "active" : "")"
                           asp-controller="Proje" asp-action="Index">Projeler</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Referans" ? "active" : "")"
                           asp-controller="Referans" asp-action="Index">Referanslar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hakkimizda" ? "active" : "")"
                           asp-controller="Hakkimizda" asp-action="Index">Hakkımızda</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")"
                           asp-controller="Blog" asp-action="Index">Blog</a>
                    </li>
                </ul>
                <a asp-controller="Iletisim" asp-action="Index" class="btn btn-gold ms-lg-3">
                    Teklif Al
                </a>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- ── Footer ───────────────────────────────────────────── -->
    <footer>
        <!-- Bülten -->
        <div class="footer-newsletter">
            <div class="container">
                <div class="row align-items-center g-3">
                    <div class="col-lg-6">
                        <h4 class="mb-1">Bahçe İlhamı Gelen Kutunuza Gelsin</h4>
                        <p class="mb-0 opacity-75">Mevsimsel öneriler ve yeni projelerimizden haberdar olun.</p>
                    </div>
                    <div class="col-lg-6">
                        <form asp-controller="Iletisim" asp-action="Abone" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="email" name="email" class="form-control footer-email-input"
                                   placeholder="E-posta adresiniz" required />
                            <button type="submit" class="btn btn-gold text-nowrap">Abone Ol</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Ana -->
        <div class="footer-main">
            <div class="container">
                <div class="row g-5">
                    <div class="col-lg-4">
                        <a asp-controller="Home" asp-action="Index" class="footer-brand d-inline-block mb-4">
                            Kömürcü <span>Peyzaj</span>
                        </a>
                        <p class="footer-desc">
                            Profesyonel peyzaj tasarımı ve uygulama hizmetleri. Bahçenizi, terasınızı ve yaşam alanlarınızı doğayla buluşturuyoruz.
                        </p>
                        <div class="footer-social mt-4">
                            @{
                                var ayarlarF = ViewBag.Ayarlar as KomürcüPeyzaj.Models.SiteAyarlari;
                            }
                            <a href="@(ayarlarF?.Instagram ?? "#")" target="_blank" rel="noopener" aria-label="Instagram">
                                <i class="bi bi-instagram"></i>
                            </a>
                            <a href="@(ayarlarF?.WhatsApp ?? "https://wa.me/905300967091")" target="_blank" rel="noopener" aria-label="WhatsApp">
                                <i class="bi bi-whatsapp"></i>
                            </a>
                            <a href="@(ayarlarF?.TikTok ?? "#")" target="_blank" rel="noopener" aria-label="TikTok">
                                <i class="bi bi-tiktok"></i>
                            </a>
                        </div>
                    </div>
                    <div class="col-lg-2 col-sm-4">
                        <h5 class="footer-heading">Sayfalar</h5>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="Index">Anasayfa</a></li>
                            <li><a asp-controller="Hizmet" asp-action="Index">Hizmetler</a></li>
                            <li><a asp-controller="Proje" asp-action="Index">Projeler</a></li>
                            <li><a asp-controller="Referans" asp-action="Index">Referanslar</a></li>
                            <li><a asp-controller="Hakkimizda" asp-action="Index">Hakkımızda</a></li>
                            <li><a asp-controller="Blog" asp-action="Index">Blog</a></li>
                            <li><a asp-controller="Iletisim" asp-action="Index">İletişim</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-sm-4">
                        <h5 class="footer-heading">Hizmetlerimiz</h5>
                        <ul class="footer-links">
                            <li><a asp-controller="Hizmet" asp-action="Index">Bahçe Tasarımı</a></li>
                            <li><a asp-controller="Hizmet" asp-action="Index">Rulo Çim</a></li>
                            <li><a asp-controller="Hizmet" asp-action="Index">Bahçe Bakımı</a></li>
                            <li><a asp-controller="Hizmet" asp-action="Index">Oyun Grubu</a></li>
                            <li><a asp-controller="Hizmet" asp-action="Index">Oturma Grubu</a></li>
                            <li><a asp-controller="Hizmet" asp-action="Index">Sulama Sistemleri</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-sm-4">
                        <h5 class="footer-heading">İletişim</h5>
                        <ul class="footer-contact">
                            <li>
                                <i class="bi bi-telephone"></i>
                                <a href="tel:@((ayarlarF?.Telefon ?? "0530 096 70 91").Replace(" ", ""))">
                                    @(ayarlarF?.Telefon ?? "0530 096 70 91")
                                </a>
                            </li>
                            @if (!string.IsNullOrEmpty(ayarlarF?.Email) && ayarlarF.Email != "— Yakında —")
                            {
                                <li>
                                    <i class="bi bi-envelope"></i>
                                    <a href="mailto:@ayarlarF.Email">@ayarlarF.Email</a>
                                </li>
                            }
                            @if (!string.IsNullOrEmpty(ayarlarF?.Adres) && ayarlarF.Adres != "— Yakında —")
                            {
                                <li>
                                    <i class="bi bi-geo-alt"></i>
                                    <span>@ayarlarF.Adres</span>
                                </li>
                            }
                            <li>
                                <i class="bi bi-clock"></i>
                                <span>Pzt–Cmt: 08:00–18:00</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Alt -->
        <div class="footer-bottom">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                <p class="mb-0">&copy; @DateTime.Now.Year Kömürcü Peyzaj — Tüm hakları saklıdır.</p>
                <p class="mb-0 footer-credit">
                    Developed by <a href="#" target="_blank">zubeyirctr</a> &#9670;
                </p>
            </div>
        </div>
    </footer>

    <!-- ── WhatsApp Floating ─────────────────────────────────── -->
    @{
        var waFloat = (ViewBag.Ayarlar as KomürcüPeyzaj.Models.SiteAyarlari)?.WhatsApp ?? "https://wa.me/905300967091";
    }
    <a href="@waFloat" class="whatsapp-float" target="_blank" rel="noopener" aria-label="WhatsApp ile yazın">
        <i class="bi bi-whatsapp"></i>
        <span class="whatsapp-tooltip">Bize Yazın</span>
    </a>

    <!-- ── KVKK Cookie Bar ───────────────────────────────────── -->
    <div id="kvkk-bar" style="display:none;">
        <div class="container d-flex align-items-center justify-content-between gap-3 flex-wrap">
            <p class="mb-0 small">
                Bu web sitesi deneyiminizi geliştirmek için çerezler kullanmaktadır.
                <a href="#" class="text-gold">Gizlilik Politikası</a>
            </p>
            <button id="kvkk-accept" class="btn btn-gold btn-sm flex-shrink-0">Kabul Et</button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
