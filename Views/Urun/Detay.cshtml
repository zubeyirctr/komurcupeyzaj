@using KomürcüPeyzaj.Models
@model Urun
@{
    ViewData["Title"] = Model.Ad;
    ViewData["BannerBaslik"] = Model.Ad;
    ViewData["BannerAlt"] = Model.Kategori;
    var benzerler = ViewBag.BenzerUrunler as List<Urun> ?? new();
}

<partial name="_PageBanner" />

<section class="section-pad">
    <div class="container">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Anasayfa</a></li>
                <li class="breadcrumb-item"><a asp-controller="Urun" asp-action="Index">Ürünler</a></li>
                <li class="breadcrumb-item active">@Model.Ad</li>
            </ol>
        </nav>

        <div class="row g-5 align-items-start">
            <!-- Görsel -->
            <div class="col-lg-6 reveal">
                <div class="urun-detay-img-wrap">
                    <img src="@(string.IsNullOrEmpty(Model.GorselUrl) ? "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=900" : Model.GorselUrl)"
                         alt="@Model.Ad" class="img-fluid rounded-3" />
                    @if (!Model.StokVarMi)
                    {
                        <div class="stok-overlay rounded-3">Tükendi</div>
                    }
                </div>
            </div>

            <!-- Bilgi -->
            <div class="col-lg-6 reveal">
                <span class="badge mb-3" style="background:var(--primary); font-weight:500; font-size:.8rem; padding:.5em 1em">@Model.Kategori</span>
                <h1 class="section-title">@Model.Ad</h1>
                <div class="gold-line mb-4"></div>

                @if (Model.Fiyat > 0)
                {
                    <p class="urun-detay-fiyat">@Model.Fiyat.ToString("N0") <span>₺</span></p>
                }
                else
                {
                    <p class="urun-detay-fiyat-ara">Fiyat için arayın</p>
                }

                <p class="text-muted mt-3 mb-4" style="line-height:1.8">@Model.Aciklama</p>

                @if (!Model.StokVarMi)
                {
                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-exclamation-triangle me-2"></i>Bu ürün şu an stokta bulunmuyor.
                    </div>
                }

                <div class="d-flex gap-3 flex-wrap">
                    <a href="https://wa.me/905300967091?text=@Uri.EscapeDataString(Model.Ad + " hakkında bilgi almak istiyorum.")"
                       target="_blank" rel="noopener" class="btn btn-success btn-lg">
                        <i class="bi bi-whatsapp me-2"></i>WhatsApp ile Sipariş
                    </a>
                    <a href="tel:05300967091" class="btn btn-outline-dark btn-lg">
                        <i class="bi bi-telephone me-2"></i>Ara
                    </a>
                </div>
            </div>
        </div>

        <!-- Benzer Ürünler -->
        @if (benzerler.Any())
        {
            <div class="mt-6">
                <h3 class="section-title mb-4">Benzer Ürünler</h3>
                <div class="row g-4">
                    @foreach (var b in benzerler)
                    {
                        <div class="col-lg-3 col-md-6 reveal">
                            <div class="urun-kart">
                                <div class="urun-kart-img">
                                    <img src="@(string.IsNullOrEmpty(b.GorselUrl) ? "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600" : b.GorselUrl)"
                                         alt="@b.Ad" loading="lazy" />
                                </div>
                                <div class="urun-kart-body">
                                    <h3 class="urun-kart-title">@b.Ad</h3>
                                    <div class="urun-kart-footer">
                                        <span class="urun-fiyat">
                                            @if (b.Fiyat > 0) { @b.Fiyat.ToString("N0") <small>₺</small> }
                                            else { <span class="text-muted fs-6">Fiyat için arayın</span> }
                                        </span>
                                        <a href="/urunler/@b.Id" class="btn btn-sm btn-outline-primary">İncele</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

    </div>
</section>
