@using KomürcüPeyzaj.Models
@model SSSMadde
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "SSS Düzenle";
}

<div class="card shadow-sm" style="max-width:680px">
    <div class="card-body p-4">
        <form asp-action="SssDuzenle" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="Soru" class="form-label">Soru *</label>
                <input asp-for="Soru" class="form-control" />
                <span asp-validation-for="Soru" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Cevap" class="form-label">Cevap *</label>
                <textarea asp-for="Cevap" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Cevap" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Sira" class="form-label">Sıra</label>
                    <input asp-for="Sira" class="form-control" type="number" />
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-gold">Güncelle</button>
                <a asp-action="SSS" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
