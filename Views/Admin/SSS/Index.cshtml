@using KomürcüPeyzaj.Models
@model List<SSSMadde>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "SSS";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold">Sık Sorulan Sorular</h5>
    <a asp-action="SssOlustur" class="btn btn-gold btn-sm">
        <i class="bi bi-plus me-1"></i>Yeni Ekle
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Soru</th>
                    <th>Durum</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="text-muted">@s.Sira</td>
                        <td>@s.Soru</td>
                        <td>
                            @if (s.AktifMi)
                            { <span class="badge bg-success">Aktif</span> }
                            else
                            { <span class="badge bg-secondary">Pasif</span> }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="SssDuzenle" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                <form asp-action="SssSil" asp-route-id="@s.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Bu SSS maddesini silmek istediğinizden emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger">Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">Henüz SSS maddesi yok.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
