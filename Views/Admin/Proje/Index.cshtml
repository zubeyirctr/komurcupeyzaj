@using KomürcüPeyzaj.Models
@model List<Proje>
@{
    ViewData["Title"] = "Projeler";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Tüm Projeler</h5>
    <a href="/admin/projeler/olustur" class="btn btn-success"><i class="bi bi-plus me-1"></i>Yeni Proje</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Görsel</th>
                    <th>Ad</th>
                    <th>Konum</th>
                    <th>Kategori</th>
                    <th>Hizmet</th>
                    <th>Öne Çıkan</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <img src="@p.KapakGorsel" alt="@p.Ad"
                                 style="width:60px;height:45px;object-fit:cover;border-radius:6px" />
                        </td>
                        <td class="fw-semibold">@p.Ad</td>
                        <td class="text-muted small">@p.Konum</td>
                        <td><span class="badge-kategori">@p.Kategori</span></td>
                        <td class="small">@p.Hizmet?.Ad</td>
                        <td>
                            @if (p.OneIkartilsinMi)
                            {
                                <i class="bi bi-star-fill text-warning"></i>
                            }
                        </td>
                        <td>
                            <a href="/admin/projeler/duzenle/@p.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                            <a href="/admin/projeler/sil/@p.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
