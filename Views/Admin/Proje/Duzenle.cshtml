@using KomürcüPeyzaj.Models
@model Proje
@{
    ViewData["Title"] = "Proje Düzenle";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Proje Düzenle</h5>
    <a href="/admin/projeler" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Geri</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Duzenle" method="post">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Ad" class="form-label fw-medium"></label>
                    <input asp-for="Ad" class="form-control" />
                    <span asp-validation-for="Ad" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Kategori" class="form-label fw-medium"></label>
                    <input asp-for="Kategori" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Konum" class="form-label fw-medium"></label>
                    <input asp-for="Konum" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="TamamlanmaTarihi" class="form-label fw-medium"></label>
                    <input asp-for="TamamlanmaTarihi" class="form-control" type="date" />
                </div>
                <div class="col-md-8">
                    <label asp-for="KapakGorsel" class="form-label fw-medium"></label>
                    <input asp-for="KapakGorsel" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="HizmetId" class="form-label fw-medium"></label>
                    <select asp-for="HizmetId" asp-items="ViewBag.Hizmetler" class="form-select">
                        <option value="">Hizmet seçin</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Aciklama" class="form-label fw-medium"></label>
                    <textarea asp-for="Aciklama" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Aciklama" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="OneIkartilsinMi" class="form-check-input" type="checkbox" />
                        <label asp-for="OneIkartilsinMi" class="form-check-label">Öne Çıkarılsın</label>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary px-5">Güncelle</button>
                    <a href="/admin/projeler" class="btn btn-outline-secondary ms-2">İptal</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
