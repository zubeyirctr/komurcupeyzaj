@using KomürcüPeyzaj.Models
@model List<Hizmet>
@{
    ViewData["Title"] = "Hizmetler";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Tüm Hizmetler</h5>
    <a href="/admin/hizmetler/olustur" class="btn btn-success"><i class="bi bi-plus me-1"></i>Yeni Hizmet</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Sıra</th>
                    <th>İkon</th>
                    <th>Ad</th>
                    <th>Fiyat</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model)
                {
                    <tr>
                        <td>@h.Sira</td>
                        <td><i class="bi @h.Ikon fs-4" style="color:var(--primary)"></i></td>
                        <td class="fw-semibold">@h.Ad</td>
                        <td>@h.BaslangicFiyati.ToString("N0") ₺</td>
                        <td>
                            @if (h.AktifMi)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td>
                            <a href="/admin/hizmetler/duzenle/@h.Id" class="btn btn-sm btn-outline-primary me-1"
                               data-bs-toggle="tooltip" title="Düzenle"><i class="bi bi-pencil"></i></a>
                            <a href="/admin/hizmetler/sil/@h.Id" class="btn btn-sm btn-outline-danger"
                               data-bs-toggle="tooltip" title="Sil"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
