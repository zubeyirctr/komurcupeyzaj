@using KomürcüPeyzaj.Models
@model List<BlogYazisi>
@{
    ViewData["Title"] = "Blog Yazıları";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Blog Yazıları</h5>
    <a href="/admin/blog/olustur" class="btn btn-success"><i class="bi bi-plus me-1"></i>Yeni Yazı</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Başlık</th>
                    <th>Yazar</th>
                    <th>Tarih</th>
                    <th>Okunma</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td class="fw-semibold">@b.Baslik</td>
                        <td class="text-muted small">@b.Yazar</td>
                        <td class="text-muted small">@b.YayinTarihi.ToString("dd MMM yyyy")</td>
                        <td><span class="badge bg-light text-dark"><i class="bi bi-eye me-1"></i>@b.OkunmaSayisi</span></td>
                        <td>
                            @if (b.YayindaMi)
                            {
                                <span class="badge bg-success">Yayında</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Taslak</span>
                            }
                        </td>
                        <td>
                            <a href="/admin/blog/duzenle/@b.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                            <a href="/admin/blog/sil/@b.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
