@using KomürcüPeyzaj.Models
@model BlogYazisi
@{
    ViewData["Title"] = "Yeni Blog Yazısı";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Yeni Blog Yazısı</h5>
    <a href="/admin/blog" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Geri</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Olustur" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Baslik" class="form-label fw-medium"></label>
                    <input asp-for="Baslik" class="form-control" />
                    <span asp-validation-for="Baslik" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Yazar" class="form-label fw-medium"></label>
                    <input asp-for="Yazar" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="YayinTarihi" class="form-label fw-medium"></label>
                    <input asp-for="YayinTarihi" class="form-control" type="date" />
                </div>
                <div class="col-12">
                    <label asp-for="KapakGorsel" class="form-label fw-medium"></label>
                    <input asp-for="KapakGorsel" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-12">
                    <label asp-for="KisaAciklama" class="form-label fw-medium"></label>
                    <input asp-for="KisaAciklama" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Etiketler" class="form-label fw-medium"></label>
                    <input asp-for="Etiketler" class="form-control" placeholder="peyzaj,bahçe,tasarım (virgülle ayırın)" />
                </div>
                <div class="col-12">
                    <label asp-for="Icerik" class="form-label fw-medium"></label>
                    <textarea asp-for="Icerik" class="form-control" rows="10"></textarea>
                    <span asp-validation-for="Icerik" class="text-danger small"></span>
                    <small class="text-muted">HTML içerik girilebilir.</small>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="YayindaMi" class="form-check-input" type="checkbox" />
                        <label asp-for="YayindaMi" class="form-check-label">Yayında</label>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-success px-5">Yayınla</button>
                    <a href="/admin/blog" class="btn btn-outline-secondary ms-2">İptal</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
