@using KomürcüPeyzaj.Models
@model List<IletisimMesaji>
@{
    ViewData["Title"] = "Mesajlar";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Gelen Mesajlar</h5>
    <span class="badge bg-warning text-dark fs-6">@Model.Count(m => !m.OkunduMu) okunmamış</span>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Telefon</th>
                    <th>Konu</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr class="@(!m.OkunduMu ? "fw-semibold table-warning" : "")">
                        <td>@m.AdSoyad</td>
                        <td>@m.Email</td>
                        <td class="text-muted small">@(string.IsNullOrEmpty(m.Telefon) ? "—" : m.Telefon)</td>
                        <td>@(string.IsNullOrEmpty(m.Konu) ? "—" : m.Konu)</td>
                        <td class="text-muted small">@m.GonderimTarihi.ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            @if (!m.OkunduMu)
                            {
                                <span class="badge bg-warning text-dark">Yeni</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Okundu</span>
                            }
                        </td>
                        <td>
                            <a href="/admin/mesajlar/@m.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-eye"></i></a>
                            <form asp-action="Sil" asp-route-id="@m.Id" method="post" style="display:inline"
                                  onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
