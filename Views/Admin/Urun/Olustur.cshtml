@using KomürcüPeyzaj.Models
@model Urun
@{
    ViewData["Title"] = "Yeni Ürün";
    Layout = "_AdminLayout";
    var kategoriler = new[] { "Bitki Besinleri ve Gübreler", "Tohum", "Zirai İlaçlar", "Bahçe Ekipmanları", "Torf & Bahçe Toprakları", "Rulo Çim" };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Yeni Ürün</h5>
    <a href="/admin/urunler" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Geri</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form method="post" action="/admin/urunler/olustur">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Ad" class="form-label fw-medium"></label>
                    <input asp-for="Ad" class="form-control" />
                    <span asp-validation-for="Ad" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Sira" class="form-label fw-medium"></label>
                    <input asp-for="Sira" class="form-control" type="number" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Kategori" class="form-label fw-medium"></label>
                    <select asp-for="Kategori" class="form-select">
                        <option value="">Kategori seçin...</option>
                        @foreach (var k in kategoriler)
                        {
                            <option value="@k">@k</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Fiyat" class="form-label fw-medium"></label>
                    <div class="input-group">
                        <input asp-for="Fiyat" class="form-control" type="number" step="1" min="0" />
                        <span class="input-group-text">₺</span>
                    </div>
                    <small class="text-muted">0 girerseniz "Fiyat için arayın" gösterilir.</small>
                </div>
                <div class="col-12">
                    <label asp-for="GorselUrl" class="form-label fw-medium"></label>
                    <input asp-for="GorselUrl" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-12">
                    <label asp-for="KisaAciklama" class="form-label fw-medium"></label>
                    <input asp-for="KisaAciklama" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Aciklama" class="form-label fw-medium"></label>
                    <textarea asp-for="Aciklama" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Aciklama" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-check">
                        <input asp-for="AktifMi" class="form-check-input" type="checkbox" />
                        <label asp-for="AktifMi" class="form-check-label">Aktif</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check">
                        <input asp-for="StokVarMi" class="form-check-input" type="checkbox" />
                        <label asp-for="StokVarMi" class="form-check-label">Stokta Var</label>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-success px-5">Kaydet</button>
                    <a href="/admin/urunler" class="btn btn-outline-secondary ms-2">İptal</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
