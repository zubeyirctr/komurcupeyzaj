@using KomürcüPeyzaj.Models
@model List<Urun>
@{
    ViewData["Title"] = "Ürünler";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Tüm Ürünler</h5>
    <a href="/admin/urunler/olustur" class="btn btn-success"><i class="bi bi-plus me-1"></i>Yeni Ürün</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Sıra</th>
                    <th>Görsel</th>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="text-muted">@u.Sira</td>
                        <td>
                            @if (!string.IsNullOrEmpty(u.GorselUrl))
                            {
                                <img src="@u.GorselUrl" alt="@u.Ad" style="width:48px;height:48px;object-fit:cover;border-radius:6px" />
                            }
                            else
                            {
                                <div style="width:48px;height:48px;background:#f0f0f0;border-radius:6px;display:flex;align-items:center;justify-content:center">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-semibold">@u.Ad</td>
                        <td><span class="badge bg-light text-dark border">@u.Kategori</span></td>
                        <td>
                            @if (u.Fiyat > 0) { @u.Fiyat.ToString("N0") <text>₺</text> }
                            else { <span class="text-muted small">—</span> }
                        </td>
                        <td>
                            @if (u.StokVarMi) { <span class="badge bg-success">Var</span> }
                            else { <span class="badge bg-danger">Tükendi</span> }
                        </td>
                        <td>
                            @if (u.AktifMi) { <span class="badge bg-success">Aktif</span> }
                            else { <span class="badge bg-secondary">Pasif</span> }
                        </td>
                        <td>
                            <a href="/admin/urunler/@u.Id/duzenle" class="btn btn-sm btn-outline-primary me-1"
                               data-bs-toggle="tooltip" title="Düzenle"><i class="bi bi-pencil"></i></a>
                            <a href="/admin/urunler/@u.Id/sil" class="btn btn-sm btn-outline-danger"
                               data-bs-toggle="tooltip" title="Sil"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Henüz ürün eklenmemiş.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
</script>
}
