@using KomürcüPeyzaj.Models
@{
    ViewData["Title"] = "Hizmetler";
    ViewData["BannerBaslik"] = "Hizmetlerimiz";
    ViewData["BannerAlt"] = "Peyzaj ihtiyaçlarınız için kapsamlı çözümler";
    var hizmetler = ViewBag.Hizmetler as List<Hizmet> ?? new();
    var sssler    = ViewBag.SSS as List<SSSMadde> ?? new();
}

<partial name="_PageBanner" />

<!-- ══ HİZMETLER GRID ════════════════════════════════════════════════════ -->
<section class="section-pad">
    <div class="container">
        <div class="section-header text-center reveal">
            <p class="section-eyebrow">Ne Yapıyoruz</p>
            <h2 class="section-title">Hizmet Alanlarımız</h2>
            <div class="gold-line"></div>
            <p class="mt-4 text-muted mx-auto" style="max-width:560px">
                Bahçe tasarımından sulama sistemlerine, çim döşemesinden peyzaj aydınlatmaya kadar her işi tek çatı altında sunuyoruz.
            </p>
        </div>

        <div class="row g-4 mt-4">
            @foreach (var h in hizmetler)
            {
                <div class="col-lg-4 col-md-6 reveal">
                    <a asp-controller="Hizmet" asp-action="Detay" asp-route-id="@h.Id" class="text-decoration-none">
                        <div class="hizmet-kart">
                            @if (!string.IsNullOrEmpty(h.GorselUrl))
                            {
                                <div class="hizmet-kart-img">
                                    <img src="@h.GorselUrl" alt="@h.Ad" loading="lazy" />
                                </div>
                            }
                            <div class="hizmet-kart-body">
                                <div class="hizmet-ikon"><i class="bi @h.Ikon"></i></div>
                                <h3 class="hizmet-kart-title">@h.Ad</h3>
                                <p class="hizmet-kart-desc">@h.KisaAciklama</p>
                                <span class="hizmet-link">Detaylı Bilgi <i class="bi bi-arrow-right ms-1"></i></span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ SÜREÇ ══════════════════════════════════════════════════════════════ -->
<section class="section-pad bg-light-section">
    <div class="container">
        <div class="section-header text-center reveal">
            <p class="section-eyebrow">Nasıl Çalışıyoruz</p>
            <h2 class="section-title">Hizmet Sürecimiz</h2>
            <div class="gold-line"></div>
        </div>
        <div class="row g-4 mt-4">
            <div class="col-md-3 col-sm-6 reveal">
                <div class="surec-adim">
                    <div class="surec-no">01</div>
                    <h5>Keşif</h5>
                    <p>Sahanızı yerinde ziyaret ederek analiz ve ölçüm yapıyoruz.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 reveal">
                <div class="surec-adim">
                    <div class="surec-no">02</div>
                    <h5>Tasarım</h5>
                    <p>İhtiyaçlarınıza özel konsept ve uygulama planı hazırlıyoruz.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 reveal">
                <div class="surec-adim">
                    <div class="surec-no">03</div>
                    <h5>Uygulama</h5>
                    <p>Uzman ekibimizle zamanında, titiz bir uygulama gerçekleştiriyoruz.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 reveal">
                <div class="surec-adim">
                    <div class="surec-no">04</div>
                    <h5>Teslim &amp; Bakım</h5>
                    <p>Projeyi teslim edip periyodik bakım hizmeti sunuyoruz.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ SSS ════════════════════════════════════════════════════════════════ -->
@if (sssler.Any())
{
    <section class="section-pad">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="section-header text-center reveal">
                        <p class="section-eyebrow">Merak Edilenler</p>
                        <h2 class="section-title">Sık Sorulan Sorular</h2>
                        <div class="gold-line"></div>
                    </div>
                    <div class="sss-wrap mt-5">
                        @foreach (var s in sssler)
                        {
                            <div class="sss-item reveal">
                                <button class="sss-btn">
                                    @s.Soru
                                    <i class="bi bi-plus sss-icon"></i>
                                </button>
                                <div class="sss-answer">
                                    <p>@s.Cevap</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- ══ CTA ════════════════════════════════════════════════════════════════ -->
<section class="cta-banner">
    <div class="cta-overlay"></div>
    <div class="container text-center text-white cta-content">
        <p class="section-eyebrow" style="color:var(--gold)">Ücretsiz Keşif</p>
        <h2 class="section-title text-white">Hayalinizdeki Bahçe İçin Teklif Alın</h2>
        <p class="mt-3 mb-4 opacity-75">Uzman ekibimiz projenizi yerinde değerlendirsin.</p>
        <a asp-controller="Iletisim" asp-action="Index" class="btn btn-gold btn-lg">İletişime Geç</a>
    </div>
</section>
