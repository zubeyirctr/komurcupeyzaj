@using KomürcüPeyzaj.Models
@model Hizmet
@{
    ViewData["Title"] = Model.Ad;
    ViewData["BannerBaslik"] = Model.Ad;
    ViewData["BannerAlt"] = Model.KisaAciklama;
}

<partial name="_PageBanner" />

<section class="section-pad">
    <div class="container">
        <div class="row g-5">
            <!-- İçerik -->
            <div class="col-lg-8">
                @if (!string.IsNullOrEmpty(Model.GorselUrl))
                {
                    <img src="@Model.GorselUrl" alt="@Model.Ad"
                         class="img-fluid mb-5 reveal"
                         style="width:100%; max-height:480px; object-fit:cover" />
                }

                <div class="reveal">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="hizmet-ikon"><i class="bi @Model.Ikon"></i></div>
                        <h2 class="section-title mb-0">@Model.Ad</h2>
                    </div>
                    <p class="lead text-muted">@Model.KisaAciklama</p>
                    <div class="gold-line mb-4"></div>
                    <div class="hizmet-icerik" style="line-height:1.9">
                        @Html.Raw(Model.Aciklama?.Replace("\n", "<br />"))
                    </div>
                </div>

                @if (Model.Projeler != null && Model.Projeler.Any())
                {
                    <div class="mt-6 reveal">
                        <h4 class="section-title" style="font-size:1.6rem">Bu Hizmete Ait Projeler</h4>
                        <div class="gold-line mb-4"></div>
                        <div class="row g-3">
                            @foreach (var p in Model.Projeler.Take(3))
                            {
                                <div class="col-md-4">
                                    <a asp-controller="Proje" asp-action="Detay" asp-route-id="@p.Id" class="text-decoration-none">
                                        <div class="proje-kart">
                                            <img src="@p.KapakGorsel" alt="@p.Ad" style="height:180px" loading="lazy" />
                                            <div class="proje-kart-overlay">
                                                <h3 class="proje-kart-title" style="font-size:1rem">@p.Ad</h3>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="sticky-top" style="top:100px">
                    <div class="hizmet-sidebar-card reveal">
                        <h5>Teklif Alın</h5>
                        <p class="text-muted small mt-2 mb-4">
                            Ücretsiz keşif ve danışmanlık için hemen iletişime geçin. Uzman ekibimiz 24 saat içinde geri döner.
                        </p>
                        <a asp-controller="Iletisim" asp-action="Index" class="btn btn-gold w-100 mb-2">
                            Teklif İste
                        </a>
                        <a href="tel:+905001234567" class="btn btn-outline-dark w-100">
                            <i class="bi bi-telephone me-2"></i>Hemen Ara
                        </a>
                    </div>

                    <div class="mt-4 reveal">
                        <h6 class="mb-3" style="font-family:var(--font-serif); font-size:1.1rem">Diğer Hizmetler</h6>
                        <a asp-controller="Hizmet" asp-action="Index" class="btn btn-outline-dark btn-sm w-100">
                            Tüm Hizmetleri Gör <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
