@using KomürcüPeyzaj.Models
@model List<Proje>
@{
    ViewData["Title"] = "Projeler";
    ViewData["BannerBaslik"] = "Projelerimiz";
    ViewData["BannerAlt"] = "Tamamladığımız işlerin küçük bir örneklemi";
    var kategoriler  = ViewBag.Kategoriler as List<string> ?? new();
    var secilen      = ViewBag.SecilenKategori as string ?? "";
    var oneProjeler  = ViewBag.OneProjeler as List<Proje> ?? new();
}

<partial name="_PageBanner" />

<!-- ══ KATEGORİ FİLTRE ════════════════════════════════════════════════════ -->
<section class="section-pad">
    <div class="container">
        @if (kategoriler.Any())
        {
            <div class="d-flex flex-wrap gap-2 justify-content-center mb-5 reveal">
                <button class="kategori-btn @(string.IsNullOrEmpty(secilen) ? "active" : "")" data-kategori="">
                    Tümü
                </button>
                @foreach (var k in kategoriler)
                {
                    <button class="kategori-btn @(secilen == k ? "active" : "")" data-kategori="@k">@k</button>
                }
            </div>
        }

        <!-- Grid -->
        <div class="row g-4" id="projeGrid">
            @foreach (var p in Model)
            {
                <div class="col-lg-4 col-md-6 proje-kart-wrap reveal" data-kategori="@p.Kategori">
                    <a asp-controller="Proje" asp-action="Detay" asp-route-id="@p.Id" class="text-decoration-none">
                        <div class="proje-kart">
                            <img src="@p.KapakGorsel" alt="@p.Ad" loading="lazy" />
                            <div class="proje-kart-overlay">
                                <span class="proje-kart-cat">@p.Kategori</span>
                                <h3 class="proje-kart-title">@p.Ad</h3>
                                <span class="proje-kart-loc">
                                    <i class="bi bi-geo-alt me-1"></i>@p.Konum
                                    @if (p.Hizmet != null) { <span class="ms-2">· @p.Hizmet.Ad</span> }
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted reveal">
                <i class="bi bi-images fs-1 mb-3 d-block opacity-50"></i>
                <p>Bu kategoride henüz proje bulunmuyor.</p>
            </div>
        }
    </div>
</section>

<!-- ══ CTA ════════════════════════════════════════════════════════════════ -->
<section class="cta-banner">
    <div class="cta-overlay"></div>
    <div class="container text-center text-white cta-content">
        <p class="section-eyebrow" style="color:var(--gold)">Sıradaki Proje Sizin Olsun</p>
        <h2 class="section-title text-white">Hayalinizdeki Bahçeyi Birlikte Yapalım</h2>
        <p class="mt-3 mb-4 opacity-75">Ücretsiz keşif randevusu alın.</p>
        <a asp-controller="Iletisim" asp-action="Index" class="btn btn-gold btn-lg">Teklif Al</a>
    </div>
</section>
